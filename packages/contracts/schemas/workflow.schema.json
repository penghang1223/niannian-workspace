{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niannian.local/schemas/workflow.schema.json",
  "title": "WorkflowDefinition",
  "type": "object",
  "required": ["id", "title", "goal", "created_at", "nodes", "edges", "approval_gates"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "owner", "status", "priority", "required_capabilities"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "owner": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "review", "done", "cancelled", "blocked"]
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "required_capabilities": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "inputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["blocks", "informs", "reviews", "hands_off_to"]
          }
        }
      }
    },
    "approval_gates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
